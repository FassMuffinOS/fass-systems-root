{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "support.fass.systems"
        }
      ],
      "destination": "/support.html",
      "permanent": false
    },
    {
      "source": "/team",
      "destination": "https://api.fass.systems/api/v1/team",
      "permanent": false
    },
    {
      "source": "/reps",
      "destination": "https://api.fass.systems/api/v1/voice/reps",
      "permanent": false
    },
    {
      "source": "/start",
      "destination": "https://api.fass.systems/api/v1/voice/start",
      "permanent": false
    },
    {
      "source": "/grantpath",
      "destination": "https://api.fass.systems/api/v1/voice/grantpath",
      "permanent": false
    },
    {
      "source": "/grantpath/sample",
      "destination": "https://api.fass.systems/api/v1/voice/grantpath/sample.pdf",
      "permanent": false
    },
    {
      "source": "/sales",
      "destination": "https://api.fass.systems/api/v1/sales",
      "permanent": false
    },
    {
      "source": "/ops",
      "destination": "https://api.fass.systems/api/v1/ops",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/fass-voice",
      "destination": "/fass-voice.html"
    },
    {
      "source": "/docs",
      "destination": "/docs.html"
    }
  ]
}