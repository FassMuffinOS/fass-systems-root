{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "support.fass.systems" }],
      "destination": "/support.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
